<!DOCTYPE html> 

<head>
    <title>My Animal Fact Card</title>

    <style>
        body {
            background-color: darkgreen;
            font-family: Arial, sans-serif;
        }

        .fact-file {
            background-color: lightyellow;
            color: darkslategray;
            width: 260px;
            padding: 25px;
            border: 4px solid forestgreen;
            margin: 30px;
        }

        .animal-name {
            color: forestgreen;
            font-size: 22px;
        }

        .detail {
            color: darkgreen;
        }

        .cool-fract {
            color: darkorange;
            font-size: italic;
        }


    </style>
</head>
<body>
    <div class="fact-file">
        <h2 class="animal name">Snow Lepard</h2>
        <p class="detail">Type:Big Cat</p>
        <p class="detail">Lives in:Mauntains ranges of Central Asia</p>
        <p class="detail">Diet:Dears goats and wild sheeps</p>
        <p class="cool-fact">Cool fact:Can leap up to 15 meters in one jump!</p>
    </div>
</body>